# name: test/sql/products.test
# description: wisdomtree.products — base table: typed schema (network-free) + live catalog invariants.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'wisdomtree' AS wt (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='wt.main';

# --- Schema: DESCRIBE binds only (no network), so these are fully deterministic. ---
# `products` is a base TABLE — query it with no parentheses.

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM wt.products);
----
ticker,fund_name,asset_class,category,sub_category,product_page_url

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM wt.products) WHERE column_name = 'ticker';
----
VARCHAR

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM wt.products) WHERE column_name = 'asset_class';
----
VARCHAR

# --- Live invariants: these hit WisdomTree. Assert shape, not exact (moving) values. ---

# The catalog has many funds; filter with WHERE.
query I
SELECT (count(*) > 50)::INT FROM wt.products;
----
1

# DGRW (U.S. Quality Dividend Growth Fund) is present with a non-empty fund name — via a WHERE.
query I
SELECT (count(*) = 1)::INT FROM wt.products WHERE ticker = 'DGRW' AND fund_name IS NOT NULL;
----
1

# Asset class is populated for the lineup (from the products page category tiers).
query I
SELECT (count(DISTINCT asset_class) >= 1)::INT FROM wt.products WHERE asset_class IS NOT NULL;
----
1
