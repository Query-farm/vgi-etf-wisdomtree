# name: test/sql/holdings.test
# description: wisdomtree.holdings base table — fund_ticker partition (pushdown), current holdings only.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'wisdomtree' AS wt (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='wt.main';

# --- Schema: DESCRIBE binds only (no network). `holdings` is a base TABLE. ---

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM wt.holdings WHERE fund_ticker = 'DGRW');
----
fund_ticker,as_of_date,name,ticker,figi,asset_group,weight_percent,shares,market_value

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM wt.holdings WHERE fund_ticker = 'DGRW') WHERE column_name = 'as_of_date';
----
DATE

# --- Live invariants (hit WisdomTree). ---

# Partition pushdown: WHERE fund_ticker = 'DGRW' fetches that fund's holdings, weight-descending.
query I
SELECT (count(*) > 50 AND max(weight_percent) > 0 AND bool_and(fund_ticker = 'DGRW'))::INT
FROM wt.holdings WHERE fund_ticker = 'DGRW';
----
1

# Multiple partitions at once: fund_ticker IN (...) fans out to two funds.
query I
SELECT (count(DISTINCT fund_ticker) = 2)::INT FROM wt.holdings WHERE fund_ticker IN ('DGRW', 'EPS');
----
1

# An unfiltered scan is allowed — it streams EVERY fund's holdings (one partition per fund).
# LIMIT short-circuits the stream after the first partition, so this stays cheap.
query I
SELECT (count(*) >= 1)::INT FROM (SELECT * FROM wt.holdings LIMIT 5);
----
1

# The backing scan function also works directly (pushdown).
query I
SELECT (count(*) > 50)::INT FROM wt.holdings_scan() WHERE fund_ticker = 'DGRW';
----
1
